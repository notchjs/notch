{
  "name": "@notchjs/notch",
  "version": "0.1.14",
  "description": "A dependency injection based web framework for Node.js",
  "author": "Augustus Kamau",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "keywords": [
    "notchjs",
    "notch",
    "framework"
  ],
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "tsc -p tsconfig.build.json",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "lint": "eslint \"{src,tests}/**/*.ts\" --fix",
    "test": "mocha \"tests/**/*.test.ts\"",
    "test:dev": "mocha -w --watch-files  \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test:cov": "nyc mocha \"tests/**/*.test.ts\" --reporter spec",
    "prerelease": "npm run prebuild && npm run build",
    "release": "release-it",
    "prepare": "husky install"
  },
  "dependencies": {
    "@hemjs/needle": "0.4.8",
    "@hemjs/notions": "0.2.6",
    "express": "4.18.2",
    "iterare": "1.2.1",
    "stoppable": "1.1.0"
  },
  "devDependencies": {
    "@armscye/container": "0.2.0",
    "@armscye/core": "0.1.0",
    "@armscye/handler": "0.2.0",
    "@armscye/hooks": "0.4.0",
    "@armscye/logging": "0.3.0",
    "@armscye/middleware": "0.2.0",
    "@armscye/module": "0.2.0",
    "@armscye/response": "0.3.0",
    "@commitlint/cli": "18.4.4",
    "@commitlint/config-conventional": "18.4.4",
    "@types/chai": "4.3.11",
    "@types/chai-subset": "1.3.5",
    "@types/express": "4.17.21",
    "@types/mocha": "10.0.6",
    "@types/node": "20.10.7",
    "@types/sinon": "17.0.2",
    "@types/stoppable": "1.1.3",
    "@types/supertest": "6.0.2",
    "@typescript-eslint/eslint-plugin": "6.18.1",
    "@typescript-eslint/parser": "6.18.1",
    "chai": "4.4.0",
    "chai-subset": "1.6.0",
    "eslint": "8.56.0",
    "eslint-config-prettier": "9.1.0",
    "eslint-plugin-import": "2.29.1",
    "eslint-plugin-simple-import-sort": "10.0.0",
    "husky": "8.0.3",
    "lint-staged": "15.2.0",
    "mocha": "10.2.0",
    "nyc": "15.1.0",
    "prettier": "3.1.1",
    "release-it": "17.0.1",
    "rimraf": "5.0.5",
    "sinon": "17.0.1",
    "supertest": "6.3.3",
    "ts-node": "10.9.2",
    "typescript": "5.3.3"
  },
  "engines": {
    "node": "^18.0.0 || >=20.0.0"
  },
  "homepage": "https://github.com/notchjs/notch#readme",
  "bugs": {
    "url": "https://github.com/notchjs/notch/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/notchjs/notch.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "nyc": {
    "include": [
      "src/**/*.ts"
    ],
    "exclude": [
      "**/*.js",
      "**/*.d.ts"
    ],
    "extension": [
      ".ts"
    ],
    "require": [
      "ts-node/register"
    ],
    "reporter": [
      "text-summary",
      "html"
    ],
    "sourceMap": true,
    "instrument": true
  },
  "mocha": {
    "require": [
      "ts-node/register"
    ],
    "exit": true
  }
}
